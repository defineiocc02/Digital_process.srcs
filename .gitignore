# =============================================================================
# .gitignore for SAR ADC Digital Processing Project
# Created: 2026-03-07
# Author: Zhao Yi
# =============================================================================

# -----------------------------------------------------------------------------
# Vivado Temporary Files
# -----------------------------------------------------------------------------
*.jou
*.log
*.str
*.wdb
*.bak
*.cache/
*.hw/
*.runs/
*.ip_user_files/
*.sim/
*.srcs/*.cache/
*.srcs/*.hw/

# -----------------------------------------------------------------------------
# Simulation Files
# -----------------------------------------------------------------------------
*.wcfg
*.isim/
*.xsim/
*.webtalk*
*.usage_statistics_webtalk.*

# -----------------------------------------------------------------------------
# IDE and Editor Files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Backup Files
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
*.orig

# -----------------------------------------------------------------------------
# Compiled Files
# -----------------------------------------------------------------------------
*.o
*.a
*.lib
*.dll
*.exe
*.out
*.app

# -----------------------------------------------------------------------------
# Documentation Build
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.env
.venv
venv/
ENV/

# -----------------------------------------------------------------------------
# Node.js (if any scripts use it)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
